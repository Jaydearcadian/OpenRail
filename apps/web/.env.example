# OpenRails web — copy to .env.local and fill in. Never commit .env.local.

# Sui network for wallet writes + reads
VITE_SUI_NETWORK=testnet

# OpenRails Move package id for writes. Set this to the published V1.2 package
# (scripts/publish-v1-2.sh prints it). Defaults to the V1.1 cut if unset.
VITE_OPENRAILS_PACKAGE_ID=0x...

# Receipt API base (optional override)
VITE_OPENRAILS_API_BASE_URL=https://openrails-receipt-api.microcosm.workers.dev

# ── Enoki zkLogin (Google/Facebook/Twitch social login + sponsored gas) ──
# Create an Enoki API key at the Enoki developer portal and allowlist the
# OpenRails move-call targets you sponsor (mint_and_fund_envelope, claim_settlement_round,
# cancel_paycard, resolve_residual_delta_expiry, create_nonce_account).
VITE_ENOKI_API_KEY=enoki_public_...

# OAuth client ids (configure redirect URL = this app's origin in each provider console)
VITE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
VITE_ENOKI_FACEBOOK_CLIENT_ID=
VITE_ENOKI_TWITCH_CLIENT_ID=
